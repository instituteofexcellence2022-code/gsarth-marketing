# Convex
# Get this from your Convex dashboard: https://dashboard.convex.dev
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex Site URL (for file storage / HTTP actions)
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Deployment key (only needed for CLI deployments)
# CONVEX_DEPLOYMENT=your-deployment-name
# CONVEX_DEPLOY_KEY=your-deploy-key

# Optional: OpenRouter API key (for AI/agent features)
# OPENROUTER_API_KEY=sk-or-v1-...

# Optional: Resend API key (for email features)
# RESEND_API_KEY=re_...
# RESEND_FROM=GSARTH <onboarding@resend.dev>

# Email preview sender name (display name in inbox)
# EMAIL_FROM_NAME=GSARTH

# Contact form notification destination
# CONTACT_TO_EMAIL=studyspotindia@gmail.com

# Primary: Gmail SMTP (recommended for primary delivery)
# Use an App Password (requires 2-step verification on the Google account)
# GMAIL_USER=yourname@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Recommended for Vercel: Gmail API (more reliable than SMTP in serverless)
# GMAIL_CLIENT_ID=...
# GMAIL_CLIENT_SECRET=...
# GMAIL_REFRESH_TOKEN=...
# Optional (if you used OAuth Playground): 
# GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
